<mah:MetroWindow x:Class="FileZenPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        Title="FileZen Pro"
        Height="760" Width="1220"
        MinHeight="680" MinWidth="1050"
        Background="#0F0F0F"
        GlowBrush="#7C3AED">

    <mah:MetroWindow.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="16,4"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="BorderBrush" Value="#333333"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="BorderBrush" Value="#7C3AED"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </mah:MetroWindow.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#1A1A1A" Opacity="0.95">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="FileZen Pro"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Margin="20,24,20,18"/>

                    <Button Content="Dashboard" Style="{StaticResource NavButtonStyle}" Click="Dashboard_Click"/>
                    <Button Content="Organizer" Style="{StaticResource NavButtonStyle}" Click="Organizer_Click"/>
                    <Button Content="Duplicates" Style="{StaticResource NavButtonStyle}" Click="Duplicates_Click"/>
                    <Button Content="Booster" Style="{StaticResource NavButtonStyle}" Click="Booster_Click"/>
                    <Button Content="Cleaner" Style="{StaticResource NavButtonStyle}" Click="Cleaner_Click"/>
                    <Button Content="Turbo Mode" Style="{StaticResource NavButtonStyle}" Click="TurboTab_Click"/>
                    <Button Content="Settings" Style="{StaticResource NavButtonStyle}" Click="Settings_Click"/>
                </StackPanel>

                <TextBlock x:Name="StatusText"
                           DockPanel.Dock="Bottom"
                           Text="Ready"
                           Foreground="#BDBDBD"
                           TextWrapping="Wrap"
                           Margin="20"
                           FontSize="12"/>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="20">
            <Border Background="#222"
                    CornerRadius="12"
                    Opacity="0.95"
                    Padding="22">
                <Grid>
                    <Grid x:Name="DashboardPanel">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="System Overview" FontSize="26" FontWeight="SemiBold"/>

                        <UniformGrid Grid.Row="1" Columns="3" Margin="0,18,0,18">
                            <Border Background="#2D2D2D" CornerRadius="8" Padding="16" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="CPU" Foreground="#CFCFCF"/>
                                    <TextBlock x:Name="CpuText" Text="0%" FontSize="28" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#2D2D2D" CornerRadius="8" Padding="16" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="RAM" Foreground="#CFCFCF"/>
                                    <TextBlock x:Name="RamText" Text="0%" FontSize="28" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#2D2D2D" CornerRadius="8" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Startup Apps" Foreground="#CFCFCF"/>
                                    <TextBlock x:Name="StartupCountText" Text="0" FontSize="28" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="0.9*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="CPU History" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <lvc:CartesianChart x:Name="CpuChart" Height="240"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="RAM History" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <lvc:CartesianChart x:Name="RamChart" Height="240"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="20,0,0,0">
                                <TextBlock Text="Activity" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <ListBox x:Name="ActivityListBox"
                                         Height="240"
                                         Background="#181818"
                                         Foreground="White"
                                         BorderBrush="#333"/>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <Grid x:Name="OrganizerPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="File Organizer" FontSize="26" FontWeight="SemiBold"/>

                        <DockPanel Grid.Row="1" Margin="0,18,0,14">
                            <Button Content="Choose Folder" Style="{StaticResource ActionButtonStyle}" Click="ChooseFolder_Click"/>
                            <Button Content="Scan" Style="{StaticResource ActionButtonStyle}" Click="ScanFolder_Click"/>
                            <Button Content="Organize" Style="{StaticResource ActionButtonStyle}" Click="OrganizeFolder_Click"/>
                            <TextBox x:Name="OrganizerPathTextBox"
                                     Height="38"
                                     VerticalContentAlignment="Center"
                                     Background="#111"
                                     Foreground="White"
                                     BorderBrush="#444"/>
                        </DockPanel>

                        <DataGrid x:Name="FilesGrid"
                                  Grid.Row="2"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Background="#181818"
                                  Foreground="White"
                                  RowBackground="#202020"
                                  AlternatingRowBackground="#262626">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding Extension}" Width="120"/>
                                <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="120"/>
                                <DataGridTextColumn Header="Created" Binding="{Binding Created}" Width="180"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <Grid x:Name="BoosterPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="System Booster" FontSize="26" FontWeight="SemiBold"/>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,18,0,14">
                            <Button Content="Refresh Startup Apps" Style="{StaticResource ActionButtonStyle}" Click="RefreshStartup_Click"/>
                            <Button Content="Boost Background Apps" Style="{StaticResource ActionButtonStyle}" Click="Boost_Click"/>
                        </StackPanel>

                        <DataGrid x:Name="StartupGrid"
                                  Grid.Row="2"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Background="#181818"
                                  Foreground="White"
                                  RowBackground="#202020"
                                  AlternatingRowBackground="#262626">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180"/>
                                <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="160"/>
                                <DataGridTextColumn Header="Command" Binding="{Binding Command}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <Grid x:Name="DuplicatesPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Duplicate Finder" FontSize="26" FontWeight="SemiBold"/>

                        <DockPanel Grid.Row="1" Margin="0,18,0,14">
                            <Button Content="Use Organizer Folder" Style="{StaticResource ActionButtonStyle}" Click="UseOrganizerFolderForDuplicates_Click"/>
                            <Button Content="Scan Duplicates" Style="{StaticResource ActionButtonStyle}" Click="ScanDuplicates_Click"/>
                            <Button Content="Delete Selected" Style="{StaticResource ActionButtonStyle}" Click="DeleteSelectedDuplicates_Click"/>
                            <TextBox x:Name="DuplicatePathTextBox"
                                     Height="38"
                                     VerticalContentAlignment="Center"
                                     Background="#111"
                                     Foreground="White"
                                     BorderBrush="#444"/>
                        </DockPanel>

                        <TextBlock x:Name="DuplicateResultText"
                                   Grid.Row="2"
                                   Text="Scan a folder to find duplicate files by SHA-256 hash."
                                   Foreground="#D8D8D8"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>

                        <DataGrid x:Name="DuplicateGrid"
                                  Grid.Row="3"
                                  AutoGenerateColumns="False"
                                  SelectionMode="Extended"
                                  IsReadOnly="True"
                                  Background="#181818"
                                  Foreground="White"
                                  RowBackground="#202020"
                                  AlternatingRowBackground="#262626">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Duplicate" Binding="{Binding DuplicatePath}" Width="*"/>
                                <DataGridTextColumn Header="Original" Binding="{Binding OriginalPath}" Width="*"/>
                                <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <Grid x:Name="CleanerPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Junk Cleaner" FontSize="26" FontWeight="SemiBold"/>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,18,0,14">
                            <Button Content="Scan Junk" Style="{StaticResource ActionButtonStyle}" Click="ScanJunk_Click"/>
                            <Button Content="Clean Junk" Style="{StaticResource ActionButtonStyle}" Click="CleanJunk_Click"/>
                        </StackPanel>
                        <TextBlock x:Name="CleanerResultText"
                                   Grid.Row="2"
                                   Text="Scan user temp files to estimate recoverable space."
                                   Foreground="#D8D8D8"
                                   TextWrapping="Wrap"/>
                    </Grid>

                    <Grid x:Name="TurboPanel" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Turbo Mode" FontSize="26" FontWeight="SemiBold"/>
                            <TextBlock Text="Runs safe temp cleanup and lowers priority for known background launchers where Windows allows it."
                                       Foreground="#D8D8D8"
                                       TextWrapping="Wrap"
                                       Margin="0,12,0,18"/>
                            <Button Content="Activate Turbo Mode"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Width="190"
                                    HorizontalAlignment="Left"
                                    Click="Turbo_Click"/>
                            <TextBlock x:Name="TurboResultText"
                                       Foreground="#D8D8D8"
                                       TextWrapping="Wrap"
                                       Margin="0,18,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="SettingsPanel" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Settings" FontSize="26" FontWeight="SemiBold"/>
                            <CheckBox x:Name="DarkModeCheckBox"
                                      Content="Dark mode"
                                      Foreground="White"
                                      Margin="0,18,0,8"/>
                            <CheckBox x:Name="ConfirmCleanCheckBox"
                                      Content="Confirm before deleting junk files"
                                      Foreground="White"
                                      Margin="0,0,0,8"/>
                            <CheckBox x:Name="RecursiveScanCheckBox"
                                      Content="Scan folders recursively"
                                      Foreground="White"
                                      Margin="0,0,0,8"/>
                            <CheckBox x:Name="RecycleDuplicatesCheckBox"
                                      Content="Send deleted duplicates to Recycle Bin"
                                      Foreground="White"
                                      Margin="0,0,0,8"/>
                            <CheckBox x:Name="IncludeWindowsTempCheckBox"
                                      Content="Include C:\Windows\Temp when cleaning"
                                      Foreground="White"
                                      Margin="0,0,0,8"/>
                            <TextBlock Text="Windows Temp may require administrator access. If access is denied, FileZen will skip it instead of crashing."
                                       Foreground="#D8D8D8"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,18"/>
                            <Button Content="Save Settings"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Width="150"
                                    HorizontalAlignment="Left"
                                    Click="SaveSettings_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</mah:MetroWindow>
