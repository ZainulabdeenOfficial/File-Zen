    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.9" />
    <PackageReference Include="OpenAI" Version="2.11.0" />
    <PackageReference Include="OpenAI-DotNet" Version="8.8.8" />
  </ItemGroup>

</Project>
